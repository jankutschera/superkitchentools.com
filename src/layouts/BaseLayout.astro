---
import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";
import BreadcrumbNav from "../components/BreadcrumbNav.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { getAllSisterSites } from "../lib/sisterSites.ts";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: { label: string; href: string }[];
  schemas?: string[];
  ogImage?: string;
}

const { title, description, canonical, breadcrumbs, schemas, ogImage } = Astro.props;

const siteUrl = "https://superkitchentools.com";
const resolvedCanonical = canonical ?? (siteUrl + Astro.url.pathname);

const sisterSites = getAllSisterSites();

const navLinks = [
  { label: "Best Picks", href: "/best/" },
  { label: "Guides", href: "/guides/" },
  { label: "Deals", href: "/deals/" },
  { label: "About", href: "/about/" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
  <meta name="theme-color" content="#C67B4B" />
  <SEOHead
    title={title}
    description={description}
    canonical={resolvedCanonical}
    ogImage={ogImage}
    schemas={schemas}
  />
</head>
<body class="bg-bg text-primary font-body min-h-screen flex flex-col">

  <!-- Skip to main content (accessibility) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-accent text-white px-4 py-2 rounded-md text-sm font-medium z-50"
  >
    Skip to main content
  </a>

  <!-- ============================
       HEADER
  =============================== -->
  <header class="sticky top-0 z-40 bg-bg/95 backdrop-blur-sm border-b border-gray-200/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 shrink-0 group">
          <!-- Kitchen utensil SVG mark -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#C67B4B"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="shrink-0"
          >
            <!-- Fork tines -->
            <line x1="8" y1="3" x2="8" y2="8" />
            <line x1="11" y1="3" x2="11" y2="8" />
            <!-- Fork handle -->
            <path d="M8 8 Q9.5 10 9.5 11 L9.5 21" />
            <path d="M11 8 Q9.5 10 9.5 11" />
            <!-- Knife -->
            <path d="M16 3 Q19 6 16 10 L16 21" />
          </svg>
          <div class="leading-none">
            <span class="text-base font-extrabold text-primary group-hover:text-accent transition-colors tracking-tight">
              SuperKitchenTools
            </span>
            <span class="block text-[10px] text-muted font-medium tracking-wide uppercase">
              Expert-Tested Picks
            </span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="relative px-3 py-2 text-sm font-medium text-muted hover:text-primary transition-colors after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-200 after:origin-center"
            >
              {link.label}
            </a>
          ))}
          <a
            href="/reviews/"
            class="ml-2 px-4 py-2 bg-accent text-white text-sm font-semibold rounded-lg hover:bg-accent/90 transition-colors"
          >
            All Reviews
          </a>
          <!-- Search trigger -->
          <button
            id="search-trigger"
            type="button"
            aria-label="Open search"
            class="ml-1 flex items-center justify-center w-9 h-9 rounded-md text-muted hover:text-primary hover:bg-gray-100 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </button>
        </nav>

        <!-- Mobile: search + hamburger -->
        <div class="md:hidden flex items-center gap-1">
          <button
            id="search-trigger-mobile"
            type="button"
            aria-label="Open search"
            class="flex items-center justify-center w-9 h-9 rounded-md text-muted hover:text-primary hover:bg-gray-100 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </button>
          <label
            for="mobile-menu-toggle"
            class="flex flex-col justify-center items-center w-10 h-10 cursor-pointer gap-1.5 rounded-md hover:bg-gray-100 transition-colors"
            aria-label="Toggle menu"
          >
            <span class="w-5 h-0.5 bg-primary rounded-full transition-all"></span>
            <span class="w-5 h-0.5 bg-primary rounded-full transition-all"></span>
            <span class="w-5 h-0.5 bg-primary rounded-full transition-all"></span>
          </label>
        </div>
      </div>
    </div>

    <!-- Mobile Menu (CSS-only via hidden checkbox) -->
    <input type="checkbox" id="mobile-menu-toggle" class="sr-only peer" />
    <div class="md:hidden hidden peer-checked:block border-t border-gray-200 bg-bg">
      <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2.5 text-sm font-medium text-primary hover:bg-gray-100 rounded-md transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/reviews/"
          class="mt-1 px-3 py-2.5 bg-accent text-white text-sm font-semibold rounded-lg text-center hover:bg-accent/90 transition-colors"
        >
          All Reviews
        </a>
      </nav>
    </div>
  </header>

  <!-- ============================
       BREADCRUMBS
  =============================== -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <div class="bg-gray-50 border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BreadcrumbNav items={breadcrumbs} />
      </div>
    </div>
  )}

  <!-- ============================
       MAIN CONTENT
  =============================== -->
  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <!-- ============================
       FOOTER
  =============================== -->
  <footer class="bg-primary text-gray-300 mt-16">
    <!-- Sister Sites Banner -->
    <div class="border-b border-white/8 py-3">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-600">Network</span>
        {sisterSites.map((site) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener"
            class="text-xs text-gray-500 hover:text-gray-300 transition-colors"
          >
            {site.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Main Footer -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <!-- Brand -->
        <div class="lg:col-span-2">
          <div class="flex items-center gap-2.5 mb-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C67B4B"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
            >
              <line x1="8" y1="3" x2="8" y2="8" />
              <line x1="11" y1="3" x2="11" y2="8" />
              <path d="M8 8 Q9.5 10 9.5 11 L9.5 21" />
              <path d="M11 8 Q9.5 10 9.5 11" />
              <path d="M16 3 Q19 6 16 10 L16 21" />
            </svg>
            <span class="text-base font-extrabold text-white">SuperKitchenTools</span>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed max-w-sm">
            Expert-tested kitchen gear recommendations. We research, test, and rank the best kitchen tools so you can cook better.
          </p>
          <div class="mt-4">
            <AffiliateDisclosure variant="footer" />
          </div>
        </div>

        <!-- Categories -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Top Categories</p>
          <ul class="flex flex-col gap-2">
            {[
              { label: "Chef's Knives", href: "/best/chefs-knives/" },
              { label: "Air Fryers", href: "/best/air-fryers/" },
              { label: "Stand Mixers", href: "/best/stand-mixers/" },
              { label: "Cast Iron", href: "/best/cast-iron-cookware/" },
              { label: "Coffee Makers", href: "/best/coffee-makers/" },
              { label: "Blenders", href: "/best/blenders/" },
            ].map((item) => (
              <li>
                <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-3">Company</p>
          <ul class="flex flex-col gap-2">
            {[
              { label: "About Us", href: "/about/" },
              { label: "Privacy Policy", href: "/privacy/" },
              { label: "Affiliate Disclosure", href: "/disclosure/" },
              { label: "Contact", href: "/contact/" },
            ].map((item) => (
              <li>
                <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Copyright -->
      <div class="mt-10 pt-6 border-t border-white/8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
        <p class="text-xs text-gray-600">
          &copy; 2026 SuperKitchenTools. All rights reserved.
        </p>
        <p class="text-xs text-gray-600">
          SuperKitchenTools is a participant in the Amazon Services LLC Associates Program.
        </p>
      </div>
    </div>
  </footer>

  <!-- Plausible Analytics -->
  <script defer data-domain="superkitchentools.com" src="https://applause.adhd-founder.com/js/script.js"></script>

  <!-- ============================
       SEARCH MODAL
  =============================== -->
  <div
    id="search-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
    class="fixed inset-0 z-50 hidden"
  >
    <!-- Backdrop -->
    <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- Modal panel -->
    <div class="relative z-10 flex flex-col items-center pt-16 px-4 sm:pt-24">
      <div class="w-full max-w-2xl bg-white rounded-xl shadow-2xl overflow-hidden">
        <!-- Search input row -->
        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <div id="search-container" class="flex-1 min-w-0"></div>
          <button
            id="search-close"
            type="button"
            aria-label="Close search"
            class="shrink-0 flex items-center justify-center w-8 h-8 rounded-md text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Pagefind search logic (loaded lazily on first open) -->
  <script>
    (function () {
      const modal = document.getElementById("search-modal") as HTMLElement | null;
      const backdrop = document.getElementById("search-backdrop") as HTMLElement | null;
      const closeBtn = document.getElementById("search-close") as HTMLElement | null;
      const searchContainer = document.getElementById("search-container") as HTMLElement | null;
      const triggers = [
        document.getElementById("search-trigger"),
        document.getElementById("search-trigger-mobile"),
      ].filter(Boolean) as HTMLElement[];

      if (!modal || !backdrop || !closeBtn || !searchContainer) return;

      let pagefindLoaded = false;

      function openModal() {
        modal!.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        if (!pagefindLoaded) {
          pagefindLoaded = true;
          loadPagefind();
        } else {
          focusSearchInput();
        }
      }

      function closeModal() {
        modal!.classList.add("hidden");
        document.body.style.overflow = "";
      }

      function focusSearchInput() {
        requestAnimationFrame(() => {
          const input = searchContainer!.querySelector("input");
          if (input) (input as HTMLInputElement).focus();
        });
      }

      async function loadPagefind() {
        if (!document.querySelector('link[href="/pagefind/pagefind-ui.css"]')) {
          const link = document.createElement("link");
          link.rel = "stylesheet";
          link.href = "/pagefind/pagefind-ui.css";
          document.head.appendChild(link);
        }

        try {
          // Dynamic import with computed path prevents Rollup from trying to resolve
          // the pagefind artifact (which only exists after build, not in node_modules)
          const pagefindPath = "/pagefind/pagefind-ui.js";
          // @ts-ignore — pagefind is a postbuild artifact, not resolvable at build time
          const { PagefindUI } = await import(/* @vite-ignore */ pagefindPath);
          new PagefindUI({
            element: "#search-container",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            excerptLength: 15,
          });
          focusSearchInput();
        } catch (_e) {
          const msg = document.createElement("p");
          msg.className = "p-4 text-sm text-gray-500";
          msg.textContent = "Search is only available on the live site after build.";
          searchContainer!.appendChild(msg);
        }
      }

      triggers.forEach((btn) => btn.addEventListener("click", openModal));
      closeBtn.addEventListener("click", closeModal);
      backdrop.addEventListener("click", closeModal);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal!.classList.contains("hidden")) {
          closeModal();
        }
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          if (modal!.classList.contains("hidden")) {
            openModal();
          } else {
            closeModal();
          }
        }
      });
    })();
  </script>

  <!-- Cookie Consent -->
  <CookieConsent />

</body>
</html>
