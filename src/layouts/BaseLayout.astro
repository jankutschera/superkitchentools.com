---
import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";
import BreadcrumbNav from "../components/BreadcrumbNav.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { getAllSisterSites } from "../lib/sisterSites.ts";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: { label: string; href: string }[];
  schemas?: string[];
  ogImage?: string;
}

const { title, description, canonical, breadcrumbs, schemas, ogImage } = Astro.props;

const siteUrl = "https://superkitchentools.com";
const resolvedCanonical = canonical ?? (siteUrl + Astro.url.pathname);

const sisterSites = getAllSisterSites();

const navLinks = [
  { label: "Best Picks", href: "/best/" },
  { label: "Guides", href: "/guides/" },
  { label: "Deals", href: "/deals/" },
  { label: "About", href: "/about/" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Inter (UI) + Playfair Display (editorial headings) in one request -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
  <meta name="theme-color" content="#C67B4B" />
  <SEOHead
    title={title}
    description={description}
    canonical={resolvedCanonical}
    ogImage={ogImage}
    schemas={schemas}
  />
</head>
<body class="bg-bg text-primary font-body min-h-screen flex flex-col">

  <!-- Skip to main content (accessibility) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-accent text-white px-4 py-2 rounded-md text-sm font-medium z-50"
  >
    Skip to main content
  </a>

  <!-- ============================
       HEADER — editorial masthead
  =============================== -->
  <header class="site-header">
    <div class="site-header-inner">

      <!-- Logo / Masthead -->
      <a href="/" class="site-logo" aria-label="SuperKitchenTools — home">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="26"
          height="26"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#C67B4B"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="shrink-0"
        >
          <line x1="8" y1="3" x2="8" y2="8" />
          <line x1="11" y1="3" x2="11" y2="8" />
          <path d="M8 8 Q9.5 10 9.5 11 L9.5 21" />
          <path d="M11 8 Q9.5 10 9.5 11" />
          <path d="M16 3 Q19 6 16 10 L16 21" />
        </svg>
        <div class="site-logo-text">
          <span class="site-logo-name">SuperKitchenTools</span>
          <span class="site-logo-tagline">Expert-Tested Picks</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="site-nav" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="site-nav-link">
            {link.label}
          </a>
        ))}
        <a href="/reviews/" class="site-nav-cta">
          All Reviews
        </a>
        <button
          id="search-trigger"
          type="button"
          aria-label="Open search"
          class="site-nav-search"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile controls -->
      <div class="site-header-mobile">
        <button
          id="search-trigger-mobile"
          type="button"
          aria-label="Open search"
          class="site-nav-search"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
        <label
          for="mobile-menu-toggle"
          class="mobile-hamburger"
          aria-label="Toggle menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </label>
      </div>
    </div>

    <!-- Mobile Menu (CSS-only via hidden checkbox) -->
    <input type="checkbox" id="mobile-menu-toggle" class="sr-only peer" />
    <div class="mobile-menu peer-checked:flex">
      <nav class="mobile-nav" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="mobile-nav-link">
            {link.label}
          </a>
        ))}
        <a href="/reviews/" class="mobile-nav-cta">
          All Reviews
        </a>
      </nav>
    </div>
  </header>

  <!-- ============================
       BREADCRUMBS
  =============================== -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <div class="bg-gray-50 border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BreadcrumbNav items={breadcrumbs} />
      </div>
    </div>
  )}

  <!-- ============================
       MAIN CONTENT
  =============================== -->
  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <!-- ============================
       FOOTER
  =============================== -->
  <footer class="site-footer">
    <!-- Sister Sites Banner -->
    <div class="footer-network">
      <div class="footer-inner">
        <span class="footer-network-label">Network</span>
        {sisterSites.map((site) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener"
            class="footer-network-link"
          >
            {site.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Main Footer -->
    <div class="footer-inner footer-main">
      <div class="footer-grid">

        <!-- Brand -->
        <div class="footer-brand">
          <div class="footer-logo">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C67B4B"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
            >
              <line x1="8" y1="3" x2="8" y2="8" />
              <line x1="11" y1="3" x2="11" y2="8" />
              <path d="M8 8 Q9.5 10 9.5 11 L9.5 21" />
              <path d="M11 8 Q9.5 10 9.5 11" />
              <path d="M16 3 Q19 6 16 10 L16 21" />
            </svg>
            <span class="footer-logo-name">SuperKitchenTools</span>
          </div>
          <p class="footer-description">
            Expert-tested kitchen gear recommendations. We research, test, and rank the best kitchen tools so you can cook better.
          </p>
          <AffiliateDisclosure variant="footer" />
        </div>

        <!-- Categories -->
        <div class="footer-col">
          <p class="footer-col-heading">Top Categories</p>
          <ul class="footer-links">
            {[
              { label: "Chef's Knives", href: "/best/chefs-knives/" },
              { label: "Air Fryers", href: "/best/air-fryers/" },
              { label: "Stand Mixers", href: "/best/stand-mixers/" },
              { label: "Cast Iron", href: "/best/cast-iron-cookware/" },
              { label: "Coffee Makers", href: "/best/coffee-makers/" },
              { label: "Blenders", href: "/best/blenders/" },
            ].map((item) => (
              <li><a href={item.href} class="footer-link">{item.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div class="footer-col">
          <p class="footer-col-heading">Company</p>
          <ul class="footer-links">
            {[
              { label: "About Us", href: "/about/" },
              { label: "Privacy Policy", href: "/privacy/" },
              { label: "Affiliate Disclosure", href: "/disclosure/" },
              { label: "Contact", href: "/contact/" },
            ].map((item) => (
              <li><a href={item.href} class="footer-link">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Copyright bar -->
      <div class="footer-copyright">
        <p>&copy; 2026 SuperKitchenTools. All rights reserved.</p>
        <p>SuperKitchenTools participates in the Amazon Services LLC Associates Program.</p>
      </div>
    </div>
  </footer>

  <!-- Plausible Analytics -->
  <script defer data-domain="superkitchentools.com" src="https://applause.superkitchentools.com/js/script.file-downloads.hash.outbound-links.pageview-props.revenue.tagged-events.js"></script>
  <script>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>
  <script defer src="https://umami.adhd-founder.com/script.js" data-website-id="dbf9e63e-3bef-4b40-994e-39ac226a6ac1"></script>

  <!-- ============================
       SEARCH MODAL
  =============================== -->
  <div
    id="search-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
    class="fixed inset-0 z-50 hidden"
  >
    <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative z-10 flex flex-col items-center pt-16 px-4 sm:pt-24">
      <div class="w-full max-w-2xl bg-white rounded-sm shadow-2xl overflow-hidden border border-gray-200">
        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <div id="search-container" class="flex-1 min-w-0"></div>
          <button
            id="search-close"
            type="button"
            aria-label="Close search"
            class="shrink-0 flex items-center justify-center w-7 h-7 rounded text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Pagefind search logic (loaded lazily on first open) -->
  <script>
    (function () {
      const modal = document.getElementById("search-modal") as HTMLElement | null;
      const backdrop = document.getElementById("search-backdrop") as HTMLElement | null;
      const closeBtn = document.getElementById("search-close") as HTMLElement | null;
      const searchContainer = document.getElementById("search-container") as HTMLElement | null;
      const triggers = [
        document.getElementById("search-trigger"),
        document.getElementById("search-trigger-mobile"),
      ].filter(Boolean) as HTMLElement[];

      if (!modal || !backdrop || !closeBtn || !searchContainer) return;

      let pagefindLoaded = false;

      function openModal() {
        modal!.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        if (!pagefindLoaded) {
          pagefindLoaded = true;
          loadPagefind();
        } else {
          focusSearchInput();
        }
      }

      function closeModal() {
        modal!.classList.add("hidden");
        document.body.style.overflow = "";
      }

      function focusSearchInput() {
        requestAnimationFrame(() => {
          const input = searchContainer!.querySelector("input");
          if (input) (input as HTMLInputElement).focus();
        });
      }

      async function loadPagefind() {
        if (!document.querySelector('link[href="/pagefind/pagefind-ui.css"]')) {
          const link = document.createElement("link");
          link.rel = "stylesheet";
          link.href = "/pagefind/pagefind-ui.css";
          document.head.appendChild(link);
        }

        try {
          const pagefindPath = "/pagefind/pagefind-ui.js";
          // @ts-ignore — pagefind is a postbuild artifact, not resolvable at build time
          const { PagefindUI } = await import(/* @vite-ignore */ pagefindPath);
          new PagefindUI({
            element: "#search-container",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            excerptLength: 15,
          });
          focusSearchInput();
        } catch (_e) {
          const msg = document.createElement("p");
          msg.className = "p-4 text-sm text-gray-500";
          msg.textContent = "Search is only available on the live site after build.";
          searchContainer!.appendChild(msg);
        }
      }

      triggers.forEach((btn) => btn.addEventListener("click", openModal));
      closeBtn.addEventListener("click", closeModal);
      backdrop.addEventListener("click", closeModal);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal!.classList.contains("hidden")) {
          closeModal();
        }
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          if (modal!.classList.contains("hidden")) {
            openModal();
          } else {
            closeModal();
          }
        }
      });
    })();
  </script>

  <!-- Cookie Consent -->
  <CookieConsent />

</body>
</html>

<style>
  :root {
    --copper: #C67B4B;
    --charcoal: #2D2D2D;
    --warm-white: #FAFAF8;
    --muted: #6B7280;
    --border: #E5E3DF;
    --font-editorial: 'Playfair Display', Georgia, serif;
    --font-ui: 'Inter', system-ui, sans-serif;
    --max-w: 1280px;
    --px: clamp(1rem, 4vw, 3rem);
  }

  /* ============================================================
     HEADER
  ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(250, 250, 248, 0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .site-header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
    gap: 1.5rem;
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-logo-text {
    line-height: 1;
  }

  .site-logo-name {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--charcoal);
    letter-spacing: -0.02em;
    transition: color 0.15s;
  }

  .site-logo:hover .site-logo-name {
    color: var(--copper);
  }

  .site-logo-tagline {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.125rem;
  }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  @media (max-width: 768px) {
    .site-nav {
      display: none;
    }
  }

  .site-nav-link {
    padding: 0.4375rem 0.75rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    border-radius: 3px;
    transition: color 0.15s, background 0.15s;
    position: relative;
  }

  .site-nav-link:hover {
    color: var(--charcoal);
    background: rgba(45, 45, 45, 0.05);
  }

  /* Copper underline on hover */
  .site-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 1.5px;
    background: var(--copper);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: center;
  }

  .site-nav-link:hover::after {
    transform: scaleX(1);
  }

  .site-nav-cta {
    margin-left: 0.5rem;
    padding: 0.4375rem 1rem;
    background: var(--copper);
    color: #fff;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.15s;
  }

  .site-nav-cta:hover {
    background: #a05e32;
  }

  .site-nav-search {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    margin-left: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    border-radius: 3px;
    transition: color 0.15s, background 0.15s;
  }

  .site-nav-search:hover {
    color: var(--charcoal);
    background: rgba(45, 45, 45, 0.05);
  }

  /* Mobile controls */
  .site-header-mobile {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (max-width: 768px) {
    .site-header-mobile {
      display: flex;
    }
  }

  .mobile-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 2.5rem;
    height: 2.5rem;
    gap: 0.3125rem;
    cursor: pointer;
    border-radius: 3px;
    transition: background 0.15s;
  }

  .mobile-hamburger:hover {
    background: rgba(45, 45, 45, 0.05);
  }

  .mobile-hamburger span {
    display: block;
    width: 1.25rem;
    height: 1.5px;
    background: var(--charcoal);
    border-radius: 1px;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--border);
    background: var(--warm-white);
  }

  .mobile-nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.75rem var(--px);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .mobile-nav-link {
    padding: 0.625rem 0.75rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--charcoal);
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.15s;
  }

  .mobile-nav-link:hover {
    background: rgba(45, 45, 45, 0.05);
  }

  .mobile-nav-cta {
    margin-top: 0.375rem;
    padding: 0.625rem 0.75rem;
    background: var(--copper);
    color: #fff;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 3px;
    text-align: center;
    transition: background 0.15s;
  }

  .mobile-nav-cta:hover {
    background: #a05e32;
  }

  /* ============================================================
     FOOTER
  ============================================================ */
  .site-footer {
    background: var(--charcoal);
    color: #a1a09e;
    margin-top: 5rem;
    /* Signature: copper top rule */
    border-top: 3px solid var(--copper);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding-left: var(--px);
    padding-right: var(--px);
  }

  /* Network bar */
  .footer-network {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.625rem 0;
  }

  .footer-network .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1rem;
  }

  .footer-network-label {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
  }

  .footer-network-link {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-network-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  /* Main footer */
  .footer-main {
    padding-top: 3rem;
    padding-bottom: 2.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Brand column */
  .footer-brand {
    grid-column: span 1;
  }

  @media (min-width: 769px) {
    .footer-brand {
      grid-column: span 1;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .footer-logo-name {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .footer-description {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.65;
    margin-bottom: 0.875rem;
  }

  /* Footer columns */
  .footer-col-heading {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 0.875rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Copyright */
  .footer-copyright {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-copyright p {
