---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryIcon from "../components/icons/CategoryIcon.astro";
import { getAllCategories } from "../lib/categories.ts";
import type { Category } from "../lib/products.ts";

const categories = getAllCategories().slice(0, 6);
---

<BaseLayout
  title="Page Not Found — SuperKitchenTools"
  description="Sorry, we couldn't find that page. Browse our kitchen tool categories or search our best picks."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">

    <span class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gray-100 text-muted mb-6" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
        <line x1="11" y1="8" x2="11" y2="14" />
        <line x1="8" y1="11" x2="14" y2="11" />
      </svg>
    </span>

    <h1 class="text-4xl font-extrabold text-primary font-heading mb-4">
      404 &mdash; Page Not Found
    </h1>

    <p class="text-lg text-muted leading-relaxed mb-8 max-w-lg mx-auto">
      Looks like this page got lost at the back of the cabinet. It may have been moved,
      renamed, or it never existed. Let's get you back to something useful.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-14">
      <a
        href="/"
        class="px-6 py-3 bg-accent text-white text-sm font-bold rounded-lg hover:bg-accent/90 transition-colors"
      >
        Back to Homepage
      </a>
      <a
        href="/best/"
        class="px-6 py-3 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:border-accent/30 hover:bg-gray-50 transition-colors"
      >
        Browse Best Picks
      </a>
    </div>

    <!-- Popular Categories -->
    <div class="text-left">
      <h2 class="text-base font-bold text-primary mb-4 text-center">Popular Categories</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {categories.map((cat: Category) => (
          <a
            href={`/best/${cat.slug}/`}
            class="group flex items-center gap-3 px-4 py-3 bg-white border border-gray-100 rounded-xl hover:border-accent/30 hover:shadow-sm transition-all"
          >
            <span class="shrink-0 text-muted group-hover:text-accent transition-colors" aria-hidden="true">
              <CategoryIcon slug={cat.slug} size={20} />
            </span>
            <span class="text-sm font-medium text-primary group-hover:text-accent transition-colors leading-snug">
              {cat.displayName}
            </span>
          </a>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>
