---
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Privacy Policy", href: "/privacy/" },
];

const lastUpdated = "March 2026";
---

<BaseLayout
  title="Privacy Policy — SuperKitchenTools"
  description="SuperKitchenTools privacy policy. We use Plausible Analytics (no cookies, no personal data) and Amazon affiliate links. We collect no email addresses or account data."
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <h1 class="text-3xl font-extrabold text-primary font-heading mb-2">Privacy Policy</h1>
    <p class="text-sm text-muted mb-10">Last updated: {lastUpdated}</p>

    <div class="prose prose-sm max-w-none flex flex-col gap-8">

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Overview</h2>
        <p class="text-muted leading-relaxed">
          SuperKitchenTools.com is committed to your privacy. This page explains what data we collect,
          why we collect it, and how it is used. The short version: we collect very little, we store
          even less, and we never sell your data.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Analytics: Plausible (No Cookies, No Personal Data)</h2>
        <p class="text-muted leading-relaxed mb-3">
          We use <strong>Plausible Analytics</strong> to understand how visitors use our site. Plausible is a
          privacy-first analytics tool with the following properties:
        </p>
        <ul class="flex flex-col gap-2 text-muted">
          {[
            "No cookies are set by Plausible — ever.",
            "No personal data is collected or stored.",
            "No cross-site tracking or fingerprinting.",
            "IP addresses are not stored — they are used only to derive a country and immediately discarded.",
            "All data is aggregated. We see page view counts and referral sources, not individual user behavior.",
            "Plausible is fully GDPR, CCPA, and PECR compliant.",
            "We self-host our Plausible instance at applause.adhd-founder.com.",
          ].map((item) => (
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-success shrink-0 fill-current" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <p class="text-muted leading-relaxed mt-3">
          You can learn more at <a href="https://plausible.io/privacy-focused-web-analytics" target="_blank" rel="noopener" class="text-accent hover:underline">plausible.io</a>.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Amazon Affiliate Links</h2>
        <p class="text-muted leading-relaxed">
          SuperKitchenTools participates in the Amazon Services LLC Associates Program. When you click
          an Amazon link on our site, you are directed to Amazon.com. Amazon may set cookies on your
          browser to track your session for commission purposes — this is governed by{" "}
          <a href="https://www.amazon.com/gp/help/customer/display.html?nodeId=468496" target="_blank" rel="noopener" class="text-accent hover:underline">Amazon's Privacy Notice</a>,
          not ours. We do not receive any personal information from Amazon about your purchases.
        </p>
        <p class="text-muted leading-relaxed mt-3">
          Our affiliate participation does not affect the price you pay. See our{" "}
          <a href="/disclosure/" class="text-accent hover:underline">Affiliate Disclosure</a> for full details.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">What We Do Not Collect</h2>
        <ul class="flex flex-col gap-2 text-muted">
          {[
            "Email addresses — we have no newsletter or mailing list.",
            "Account information — there is no account system on this site.",
            "Payment information — we process no payments.",
            "Personal information of any kind.",
            "Any data from children under 13.",
          ].map((item) => (
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Third-Party Services</h2>
        <p class="text-muted leading-relaxed mb-3">
          In addition to the services above, this site may load external resources:
        </p>
        <ul class="flex flex-col gap-2 text-muted">
          <li class="flex items-start gap-2.5">
            <span class="w-1.5 h-1.5 mt-2 rounded-full bg-muted shrink-0"></span>
            <span><strong class="text-primary">Google Fonts</strong> — loaded at page render to serve our typography. Google may log the request IP per their privacy policy.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-1.5 h-1.5 mt-2 rounded-full bg-muted shrink-0"></span>
            <span><strong class="text-primary">Amazon product images</strong> — served from Amazon's CDN (media-amazon.com). Amazon may log the request per their privacy policy.</span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Hosting & Infrastructure</h2>
        <p class="text-muted leading-relaxed">
          This site is hosted on Vercel. Vercel may log server-side request data (IP address, user agent,
          path) in access logs for security and debugging purposes. These logs are retained per Vercel's
          standard policy and are not accessible to us in a user-identifiable form.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Your Rights</h2>
        <p class="text-muted leading-relaxed">
          Because we do not collect personal data, there is nothing to access, correct, or delete. If
          you have a privacy concern or believe we have inadvertently collected personal data, contact
          us at{" "}
          <a href="mailto:hello@superkitchentools.com" class="text-accent hover:underline">hello@superkitchentools.com</a>
          {" "}and we will investigate promptly.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Changes to This Policy</h2>
        <p class="text-muted leading-relaxed">
          If we materially change this policy — for example, by adding an email list or new tracking —
          we will update the "last updated" date at the top of this page. We will not make changes
          that retroactively affect data collected before the change date.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-primary mb-3">Contact</h2>
        <p class="text-muted leading-relaxed">
          Questions about this policy? Email us:{" "}
          <a href="mailto:hello@superkitchentools.com" class="text-accent hover:underline">hello@superkitchentools.com</a>
        </p>
      </section>

    </div>
  </div>
</BaseLayout>
