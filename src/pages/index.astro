---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import ProductCard from "../components/ProductCard.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import { getAllCategories } from "../lib/categories.ts";
import { getAllProducts } from "../lib/products.ts";
import { generateItemListSchema } from "../lib/seo.ts";

const categories = getAllCategories();
const allProducts = getAllProducts();

// Featured products: first isBestSeller from each of 3 categories
const featuredProducts = allProducts
  .filter((p) => p.isBestSeller)
  .slice(0, 6);

const schema = generateItemListSchema(featuredProducts, "Best Kitchen Tools 2026");
---

<BaseLayout
  title="SuperKitchenTools — Expert-Tested Kitchen Gear Reviews 2026"
  description="Find the best chef's knives, air fryers, stand mixers, and more. Expert-tested, honestly reviewed kitchen tools for every budget and cooking style."
  schemas={[schema]}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-gray-50 to-bg py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-widest text-accent mb-4">
        Expert-Tested Kitchen Gear
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-primary leading-tight mb-6 font-heading">
        Find the Best<br class="hidden sm:block" />
        Kitchen Tools in 2026
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-8 leading-relaxed">
        We research, test, and rank the top kitchen gear across 10 categories.
        No fluff — just honest picks that help you cook better.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/best/"
          class="px-6 py-3 bg-accent text-white text-base font-semibold rounded-lg hover:bg-accent/90 transition-colors"
        >
          See Best Picks
        </a>
        <a
          href="/reviews/"
          class="px-6 py-3 bg-white text-primary text-base font-semibold rounded-lg border border-gray-200 hover:border-accent/40 hover:bg-gray-50 transition-colors"
        >
          Browse All Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- Disclosure -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <AffiliateDisclosure variant="inline" />
  </div>

  <!-- Categories -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary font-heading">Shop by Category</h2>
        <p class="text-muted mt-1">10 categories covering every corner of your kitchen</p>
      </div>
      <a href="/best/" class="hidden sm:inline-block text-sm text-accent font-medium hover:underline">
        View all &rarr;
      </a>
    </div>
    <CategoryGrid categories={categories} />
  </section>

  <!-- Featured Products -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-primary font-heading">Top-Rated Picks</h2>
          <p class="text-muted mt-1">Best sellers across our most popular categories</p>
        </div>
        <a href="/reviews/" class="hidden sm:inline-block text-sm text-accent font-medium hover:underline">
          All reviews &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-primary font-heading text-center mb-12">
      How We Pick the Best Gear
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Research-First -->
      <div class="text-center">
        <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent/8 text-accent mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
            <path d="M11 8v6" />
            <path d="M8 11h6" />
          </svg>
        </span>
        <h3 class="text-lg font-bold text-primary mb-2 font-heading">Research-First</h3>
        <p class="text-muted text-sm leading-relaxed">Every recommendation starts with thorough research across professional reviews, user feedback, and expert testing data.</p>
      </div>

      <!-- Honest Trade-offs -->
      <div class="text-center">
        <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent/8 text-accent mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="3" x2="12" y2="21" />
            <path d="M5 7l7-4 7 4" />
            <path d="M5 17l7 4 7-4" />
            <path d="M3 11l9-5 9 5" />
            <path d="M3 13l9 5 9-5" />
          </svg>
        </span>
        <h3 class="text-lg font-bold text-primary mb-2 font-heading">Honest Trade-offs</h3>
        <p class="text-muted text-sm leading-relaxed">We tell you what each product does badly, not just what it does well. Real cons, not invented ones.</p>
      </div>

      <!-- Clear Guidance -->
      <div class="text-center">
        <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent/8 text-accent mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
        </span>
        <h3 class="text-lg font-bold text-primary mb-2 font-heading">Clear Guidance</h3>
        <p class="text-muted text-sm leading-relaxed">We explain who each product is right for — so you buy the correct tool for your actual cooking needs.</p>
      </div>
    </div>
  </section>
</BaseLayout>
