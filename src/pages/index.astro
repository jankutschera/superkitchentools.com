---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import ProductCard from "../components/ProductCard.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import { getAllCategories } from "../lib/categories.ts";
import { getAllProducts } from "../lib/products.ts";
import { generateItemListSchema } from "../lib/seo.ts";

const categories = getAllCategories();
const allProducts = getAllProducts();

const featuredProducts = allProducts
  .filter((p) => p.isBestSeller)
  .slice(0, 6);

const schema = generateItemListSchema(featuredProducts, "Best Kitchen Tools 2026");
---

<BaseLayout
  title="SuperKitchenTools — Expert-Tested Kitchen Gear Reviews 2026"
  description="Find the best chef's knives, air fryers, stand mixers, and more. Expert-tested, honestly reviewed kitchen tools for every budget and cooking style."
  schemas={[schema]}
>

  <!-- ============================
       HERO — full-width photo
  =============================== -->
  <section class="relative min-h-[580px] md:min-h-[640px] flex items-center overflow-hidden">
    <!-- Background image -->
    <div
      class="absolute inset-0 category-hero-bg"
      style="background-image: url('/images/hero.jpg');"
      aria-hidden="true"
    ></div>
    <!-- Dark gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/55 to-black/30" aria-hidden="true"></div>
    <!-- Subtle texture overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/40" aria-hidden="true"></div>

    <!-- Content -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-2xl">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-5 bg-black/30 backdrop-blur-sm px-3 py-1 rounded-full border border-accent/30">
          Expert-Tested Kitchen Gear
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] mb-6 font-heading">
          Find Kitchen Tools<br class="hidden sm:block" />
          Worth Buying
        </h1>
        <p class="text-lg md:text-xl text-white/85 max-w-xl mb-10 leading-relaxed font-body">
          We research, test, and rank the top kitchen gear across 10 categories.
          Honest picks — no fluff, no hype.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/best/"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-accent text-white text-base font-semibold rounded-lg hover:bg-amber-600 transition-colors shadow-lg"
          >
            See Best Picks
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/reviews/"
            class="inline-flex items-center justify-center px-7 py-3.5 bg-white/15 backdrop-blur-sm text-white text-base font-semibold rounded-lg border border-white/30 hover:bg-white/25 transition-colors"
          >
            Browse All Reviews
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       TRUST BAR
  =============================== -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        <div class="flex items-center gap-2 text-sm text-muted">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <span>100+ products tested</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-muted">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          <span>4.7 avg. rating</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-muted">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Updated March 2026</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-muted">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span>Editorially independent</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================
       AFFILIATE DISCLOSURE
  =============================== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <AffiliateDisclosure variant="inline" />
  </div>

  <!-- ============================
       CATEGORIES — photo cards
  =============================== -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-2">What We Cover</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-primary font-heading leading-tight">Shop by Category</h2>
        <p class="text-muted mt-2 text-base">10 categories, expert-ranked picks in each</p>
      </div>
      <a href="/best/" class="hidden sm:inline-flex items-center gap-1.5 text-sm text-accent font-semibold hover:text-amber-700 transition-colors">
        View all categories
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
    <CategoryGrid categories={categories} />
  </section>

  <!-- ============================
       FEATURED PRODUCTS — editorial
  =============================== -->
  <section class="bg-gray-50 border-y border-gray-200 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-2">Editors' Picks</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-primary font-heading leading-tight">Top-Rated Picks</h2>
          <p class="text-muted mt-2 text-base">Best sellers across our most popular categories</p>
        </div>
        <a href="/reviews/" class="hidden sm:inline-flex items-center gap-1.5 text-sm text-accent font-semibold hover:text-amber-700 transition-colors">
          All reviews
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================
       HOW WE PICK — editorial trust
  =============================== -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="text-center mb-14">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-3">Our Methodology</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-primary font-heading">
        How We Pick the Best Gear
      </h2>
      <p class="text-muted mt-3 text-base max-w-xl mx-auto">
        Every recommendation follows the same process — no shortcuts, no sponsored placements.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

      <!-- Research-First -->
      <div class="flex flex-col">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-5 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C67B4B" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">Research-First</h3>
        <p class="text-muted text-sm leading-relaxed">Every recommendation starts with thorough research across professional reviews, user feedback, and hands-on testing data from verified purchasers.</p>
      </div>

      <!-- Honest Trade-offs -->
      <div class="flex flex-col">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-5 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C67B4B" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
            <polyline points="17 6 23 6 23 12" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">Honest Trade-offs</h3>
        <p class="text-muted text-sm leading-relaxed">We tell you what each product does badly, not just what it does well. Real cons, not invented ones — so you know exactly what you're buying.</p>
      </div>

      <!-- Clear Guidance -->
      <div class="flex flex-col">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-5 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C67B4B" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20h9" />
            <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-primary mb-3 font-heading">Clear Guidance</h3>
        <p class="text-muted text-sm leading-relaxed">We explain exactly who each product is right for — so you buy the correct tool for your actual cooking style and budget, not ours.</p>
      </div>
    </div>
  </section>

  <!-- ============================
       RECENT PICKS — narrow strip
  =============================== -->
  <section class="bg-primary py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16">
        <div class="shrink-0 text-center md:text-left">
          <p class="text-accent text-xs font-semibold uppercase tracking-[0.12em] mb-2">Ready to buy?</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-white font-heading leading-tight">
            Find your perfect<br />kitchen tool today
          </h2>
        </div>
        <div class="flex flex-wrap gap-3 justify-center md:justify-start">
          {[
            { label: "Best Chef's Knives", href: "/best/chefs-knives/" },
            { label: "Best Air Fryers", href: "/best/air-fryers/" },
            { label: "Best Stand Mixers", href: "/best/stand-mixers/" },
            { label: "Best Cast Iron", href: "/best/cast-iron-cookware/" },
            { label: "Best Coffee Makers", href: "/best/coffee-makers/" },
            { label: "Best Blenders", href: "/best/blenders/" },
          ].map((item) => (
            <a
              href={item.href}
              class="px-4 py-2 bg-white/10 text-white/90 text-sm font-medium rounded-lg border border-white/15 hover:bg-white/20 hover:text-white transition-colors"
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
