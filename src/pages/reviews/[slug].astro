---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import ProsConsList from "../../components/ProsConsList.astro";
import BuyBox from "../../components/BuyBox.astro";
import DealBadge from "../../components/DealBadge.astro";
import RatingStars from "../../components/RatingStars.astro";
import ProductCard from "../../components/ProductCard.astro";
import ArticleTOC from "../../components/ArticleTOC.astro";
import SisterSiteLink from "../../components/SisterSiteLink.astro";
import ProductImage from "../../components/ProductImage.astro";
import { getAllProducts, getProductsByCategory } from "../../lib/products.ts";
import { getCategory } from "../../lib/categories.ts";
import { affiliateUrl } from "../../lib/affiliateUrl.ts";
import {
  generateProductSchema,
  generateFAQSchema,
  generateBreadcrumbSchema,
} from "../../lib/seo.ts";
import { getSisterSitesForCategory } from "../../lib/sisterSites.ts";

export function getStaticPaths() {
  const products = getAllProducts();
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const category = getCategory(product.category);
const categoryDisplayName = category?.displayName ?? product.category;

const allCatProducts = getProductsByCategory(product.category);
const similarProducts = allCatProducts
  .filter((p) => p.slug !== product.slug)
  .slice(0, 3);

function buildVerdict(pros: string[], cons: string[], name: string): string {
  const topPro = pros[0] ?? "a solid choice";
  const topCon = cons[0] ?? "a minor limitation";
  return `The ${name} earns a strong recommendation thanks to ${topPro.toLowerCase()}. The main caveat is that ${topCon.toLowerCase()}, so keep that in mind before buying. Overall, it delivers excellent value within its price range and is a well-rounded pick for most home cooks.`;
}

function buildWhoShouldBuy(product: { name: string; pros: string[]; features: string[]; price: number; category: string }): string {
  const categoryLabel = product.category.replace(/-/g, " ");
  if (product.price < 50) {
    const topPro = (product.pros[0] ?? "reliable performance").toLowerCase();
    return `Best for beginners, students, or anyone who wants solid ${categoryLabel} performance without spending more than $${Math.ceil(product.price)}. The ${product.name} delivers ${topPro} at a price point that makes it easy to recommend without hesitation. It's particularly well-suited to first-time buyers who want to try a category before committing to a more expensive model.`;
  } else if (product.price < 150) {
    const topPro = (product.pros[0] ?? "versatile performance").toLowerCase();
    const topFeature = (product.features[0] ?? "its feature set").toLowerCase();
    return `Ideal for home cooks who use ${categoryLabel} regularly and want ${topPro} without paying a premium price. The ${product.name} sits in the sweet spot where quality and value intersect — you get ${topFeature} at a price that justifies the investment for anyone who cooks more than a few times a week. Not the choice for professionals, but perfect for the serious home cook.`;
  } else {
    const topPro = (product.pros[0] ?? "exceptional quality and performance").toLowerCase();
    const topFeature = (product.features[0] ?? "its premium construction").toLowerCase();
    return `Worth it for serious cooks who rely on their ${categoryLabel} daily and value ${topPro}. The ${product.name} is a long-term investment — you're paying for ${topFeature}, durability that outlasts budget alternatives by years, and the kind of performance that makes everyday cooking genuinely better. Not for casual cooks or those who rarely use this category, but for those who do, it's the right tool for the long haul.`;
  }
}

const faqs = [
  {
    question: `Is the ${product.name} worth buying in 2026?`,
    answer: `Yes — the ${product.name} remains one of the top-rated options in the ${categoryDisplayName} category. With a ${product.rating.toFixed(1)}-star rating from over ${product.reviewCount.toLocaleString()} reviews, it has a proven track record. ${product.pros[0] ?? "Solid build quality"} makes it a reliable choice at its $${product.price.toFixed(2)} price point.`,
  },
  {
    question: `How does the ${product.name} compare to alternatives?`,
    answer: `The ${product.name} stands out for ${(product.pros[0] ?? "its performance").toLowerCase()}. The main trade-off is ${(product.cons[0] ?? "the price").toLowerCase()}. For most home cooks, it offers a strong balance of quality and value — check our full ${categoryDisplayName} comparison for a detailed side-by-side breakdown.`,
  },
  {
    question: `What's included with the ${product.name}?`,
    answer: `The ${product.name} includes the main unit and standard accessories for the ${categoryDisplayName} category. ${product.features.length > 0 ? `Key included features: ${product.features.slice(0, 2).join("; ")}.` : ""} Check the Amazon listing for the full, up-to-date contents list as bundled accessories may vary.`,
  },
];

const sisterSites = getSisterSitesForCategory(product.category);
const firstSisterSite = sisterSites[0];

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: `Best ${categoryDisplayName}`, href: `/best/${product.category}/` },
  { label: `${product.name} Review`, href: `/reviews/${product.slug}/` },
];

const tocHeadings = [
  { text: "Our Verdict", slug: "verdict", depth: 2 },
  { text: "Specifications", slug: "specs", depth: 2 },
  { text: "Pros & Cons", slug: "pros-cons", depth: 2 },
  { text: "What We Like", slug: "what-we-like", depth: 2 },
  { text: "What Could Be Better", slug: "what-could-be-better", depth: 2 },
  { text: "Who Should Buy This", slug: "who-should-buy", depth: 2 },
  { text: "Frequently Asked Questions", slug: "faq", depth: 2 },
  { text: "Similar Products", slug: "similar-products", depth: 2 },
];

const schemas = [
  generateProductSchema(product),
  generateFAQSchema(faqs),
  generateBreadcrumbSchema([
    { name: "Home", url: "https://superkitchentools.com/" },
    {
      name: `Best ${categoryDisplayName}`,
      url: `https://superkitchentools.com/best/${product.category}/`,
    },
    {
      name: `${product.name} Review`,
      url: `https://superkitchentools.com/reviews/${product.slug}/`,
    },
  ]),
];

const amazonUrl = affiliateUrl(product.asin);
const verdict = buildVerdict(product.pros, product.cons, product.name);
const whoShouldBuy = buildWhoShouldBuy({ ...product, category: product.category });
const formatted = product.price.toLocaleString("en-US", { style: "currency", currency: "USD" });
---

<BaseLayout
  title={`${product.name} Review 2026 — Is It Worth It?`}
  description={`In-depth ${product.name} review. Pros, cons, specs, and our honest verdict. ${product.rating.toFixed(1)} stars from ${product.reviewCount.toLocaleString()} reviews.`}
  breadcrumbs={breadcrumbs}
  schemas={schemas}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col lg:flex-row gap-10 xl:gap-14">

      <!-- ========================
           MAIN CONTENT — left 2/3
      ========================= -->
      <main class="flex-1 min-w-0 max-w-3xl">

        <!-- Disclosure -->
        <AffiliateDisclosure variant="inline" />

        <!-- H1 -->
        <div class="w-28 h-1 bg-accent mt-8 mb-4"></div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-primary font-heading mb-2 leading-tight">
          {product.name} Review 2026
        </h1>
        <p class="text-muted text-sm mb-6">
          By SuperKitchenTools Editorial Team &nbsp;·&nbsp; Updated March 2026
        </p>

        <!-- Product hero card -->
        <div class="flex flex-col sm:flex-row gap-6 mb-10 p-6 bg-white rounded-xl border border-gray-200 shadow-sm">
          <!-- Product image with fallback -->
          <a href={amazonUrl} rel="nofollow sponsored" target="_blank" class="shrink-0 group" aria-label={`View ${product.name} on Amazon`}>
            <div class="w-full sm:w-48 aspect-square rounded-xl bg-gray-50 border border-gray-100 overflow-hidden flex items-center justify-center p-3">
              <img
                src={product.imageUrl}
                alt={product.name}
                width="192"
                height="192"
                loading="eager"
                class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300"
                onerror={`
                  this.style.display='none';
                  var fallback = this.parentElement.querySelector('.img-fb');
                  if(fallback) fallback.style.display='flex';
                `}
              />
              <div class="img-fb hidden w-full h-full absolute inset-0 flex-col items-center justify-center gap-2 bg-gradient-to-br from-gray-100 to-gray-200 text-gray-400 p-4">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 21l12-12" /><path d="M6.5 17.5L18 3c1 0 3 1 3 3L7.5 17.5" /><path d="M3 21c0 0 2.5-.5 4-2" />
                </svg>
                <span class="text-xs text-center leading-snug">{product.name}</span>
              </div>
            </div>
          </a>

          <!-- Key facts -->
          <div class="flex flex-col gap-3 justify-center flex-1">
            <p class="text-xs font-semibold uppercase tracking-[0.1em] text-muted">{product.brand}</p>
            <h2 class="text-lg font-bold text-primary font-heading leading-snug">{product.name}</h2>
            <RatingStars rating={product.rating} reviewCount={product.reviewCount} />
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-extrabold text-primary">{formatted}</span>
              <span class="text-sm text-muted">at time of writing</span>
            </div>
            {product.isBestSeller && <span class="w-fit"><DealBadge type="best-seller" /></span>}
            {!product.isBestSeller && product.isAmazonChoice && <span class="w-fit"><DealBadge type="amazon-choice" /></span>}
            <a
              href={amazonUrl}
              rel="nofollow sponsored"
              target="_blank"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 transition-colors w-fit mt-1"
            >
              Check Price on Amazon
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Our Verdict -->
        <section id="verdict" class="mb-10">
          <h2 class="text-2xl font-bold text-primary font-heading mb-4">Our Verdict</h2>
          <div class="bg-accent/5 border-l-[3px] border-accent rounded-r-xl p-5">
            <p class="text-primary leading-relaxed">{verdict}</p>
          </div>
        </section>

        <!-- Specifications -->
        {Object.keys(product.specs).length > 0 && (
          <section id="specs" class="mb-10">
            <h2 class="text-2xl font-bold text-primary font-heading mb-4">Specifications</h2>
            <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
              <table class="w-full text-sm">
                <tbody class="divide-y divide-gray-100">
                  {Object.entries(product.specs).map(([key, val]) => (
                    <tr class="hover:bg-gray-50/70 transition-colors">
                      <td class="px-5 py-3 font-medium text-primary bg-gray-50/50 w-2/5">{key}</td>
                      <td class="px-5 py-3 text-muted">{val}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        <!-- Pros & Cons -->
        <section id="pros-cons" class="mb-10">
          <h2 class="text-2xl font-bold text-primary font-heading mb-4">Pros &amp; Cons</h2>
          <ProsConsList pros={product.pros} cons={product.cons} />
        </section>

        <!-- What We Like -->
        {product.pros.length > 0 && (
          <section id="what-we-like" class="mb-10">
            <h2 class="text-2xl font-bold text-primary font-heading mb-5">What We Like</h2>
            <div class="flex flex-col gap-4">
              {product.pros.map((pro) => (
                <div class="flex items-start gap-4 p-4 bg-emerald-50/50 border border-emerald-200 rounded-xl">
                  <div class="w-8 h-8 rounded-full bg-success/15 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-primary leading-snug">{pro}</p>
                    <p class="text-sm text-muted mt-1 leading-relaxed">
                      This is one of the standout qualities that sets the {product.name} apart from similarly priced competitors.
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- What Could Be Better -->
        {product.cons.length > 0 && (
          <section id="what-could-be-better" class="mb-10">
            <h2 class="text-2xl font-bold text-primary font-heading mb-5">What Could Be Better</h2>
            <div class="flex flex-col gap-4">
              {product.cons.map((con) => (
                <div class="flex items-start gap-4 p-4 bg-red-50/40 border border-red-200 rounded-xl">
                  <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-primary leading-snug">{con}</p>
                    <p class="text-sm text-muted mt-1 leading-relaxed">
                      Worth knowing before you buy — though for most users this won't be a dealbreaker given the overall quality.
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Who Should Buy This -->
        <section id="who-should-buy" class="mb-10">
          <h2 class="text-2xl font-bold text-primary font-heading mb-4">Who Should Buy This</h2>
          <p class="text-muted leading-relaxed">{whoShouldBuy}</p>
        </section>

        <!-- FAQ -->
        <section id="faq" class="mb-10" aria-labelledby="faq-heading">
          <h2 id="faq-heading" class="text-2xl font-bold text-primary font-heading mb-6">
            Frequently Asked Questions
          </h2>
          <div class="flex flex-col gap-3">
            {faqs.map((faq) => (
              <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
                <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none hover:bg-gray-50/70 transition-colors">
                  <span class="font-semibold text-primary text-sm leading-snug">{faq.question}</span>
                  <svg class="w-4 h-4 text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 pt-2 text-muted text-sm leading-relaxed border-t border-gray-100">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Similar Products -->
        {similarProducts.length > 0 && (
          <section id="similar-products" class="mb-10">
            <h2 class="text-2xl font-bold text-primary font-heading mb-6">
              Similar {categoryDisplayName}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {similarProducts.map((p) => (
                <ProductCard product={p} />
              ))}
            </div>
            <div class="mt-6">
              <a
                href={`/best/${product.category}/`}
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:border-accent/30 hover:bg-gray-50 transition-colors"
              >
                See All Best {categoryDisplayName}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </section>
        )}

        <!-- Sister Site Link -->
        {firstSisterSite && (
          <div class="mt-8 pt-8 border-t border-gray-100">
            <SisterSiteLink site={firstSisterSite} variant="inline" />
          </div>
        )}

      </main>

      <!-- ========================
           SIDEBAR — right 1/3
      ========================= -->
      <aside class="w-full lg:w-80 shrink-0">
        <div class="flex flex-col gap-5" style="position: sticky; top: 88px;">
          <BuyBox product={product} />
          <ArticleTOC headings={tocHeadings} />
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>
