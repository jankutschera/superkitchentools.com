---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getAllProducts } from "../../lib/products.ts";
import type { Product } from "../../lib/products.ts";

const allProducts = getAllProducts();

// Top picks: highest rating, ties broken by review count
const topPicks = [...allProducts]
  .sort((a, b) => b.rating - a.rating || b.reviewCount - a.reviewCount)
  .slice(0, 10);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Deals", href: "/deals/" },
];
---

<BaseLayout
  title="Top-Rated Kitchen Tools — SuperKitchenTools"
  description="Find the highest-rated kitchen tools right now. Top-rated picks across all categories, sorted by customer ratings and reviews."
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Hero -->
    <div class="text-center mb-14">
      <span class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent/10 text-accent mb-5" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
          <line x1="7" y1="7" x2="7.01" y2="7" />
        </svg>
      </span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary font-heading mb-4">
        Top-Rated Kitchen Tools
      </h1>
      <p class="text-lg text-muted leading-relaxed max-w-xl mx-auto">
        The highest-rated kitchen tools across all categories, hand-picked by our editorial team.
        Updated regularly.
      </p>
    </div>

    <!-- Top-Rated Products -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent text-white text-sm font-bold shrink-0" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </span>
        <div>
          <h2 class="text-2xl font-extrabold text-primary font-heading leading-tight">Top-Rated Picks</h2>
          <p class="text-sm text-muted mt-0.5">Highest-rated products across all categories</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        {topPicks.map((product: Product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
