---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getAllProducts } from "../../lib/products.ts";
import type { Product } from "../../lib/products.ts";

const allProducts = getAllProducts();

// Top 5: highest rating, ties broken by lowest price
const topPicks = [...allProducts]
  .sort((a, b) => b.rating - a.rating || a.price - b.price)
  .slice(0, 5);

// Budget picks: under $50, sorted by rating desc
const budgetPicks = [...allProducts]
  .filter((p) => p.price < 50)
  .sort((a, b) => b.rating - a.rating || a.price - b.price)
  .slice(0, 6);

// Best value: highest rating-to-price ratio
const bestValue = [...allProducts]
  .sort((a, b) => b.rating / b.price - a.rating / a.price)
  .slice(0, 5);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Deals", href: "/deals/" },
];
---

<BaseLayout
  title="Best Value Kitchen Deals — SuperKitchenTools"
  description="Find the best-value kitchen tools right now. Top-rated picks, budget buys under $50, and the best rating-to-price ratio products across all categories."
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Hero -->
    <div class="text-center mb-14">
      <span class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent/10 text-accent mb-5" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
          <line x1="7" y1="7" x2="7.01" y2="7" />
        </svg>
      </span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary font-heading mb-4">
        Best Value Kitchen Deals
      </h1>
      <p class="text-lg text-muted leading-relaxed max-w-xl mx-auto">
        Hand-picked kitchen tools with the best combination of ratings, reviews, and price.
        Updated regularly across all categories.
      </p>
    </div>

    <!-- Top 5 Best-Rated Products -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent text-white text-sm font-bold shrink-0" aria-hidden="true">1</span>
        <div>
          <h2 class="text-2xl font-extrabold text-primary font-heading leading-tight">Top 5 Best-Rated Picks</h2>
          <p class="text-sm text-muted mt-0.5">Highest-rated products across all categories</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        {topPicks.map((product: Product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </section>

    <!-- Budget Picks Under $50 -->
    {budgetPicks.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-success text-white shrink-0" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="12" y1="1" x2="12" y2="23" />
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
          </span>
          <div>
            <h2 class="text-2xl font-extrabold text-primary font-heading leading-tight">Budget Picks Under $50</h2>
            <p class="text-sm text-muted mt-0.5">Top-rated tools that won't break the bank</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {budgetPicks.map((product: Product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>
    )}

    <!-- Best Value (rating/price ratio) -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary text-white shrink-0" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
            <polyline points="17 6 23 6 23 12" />
          </svg>
        </span>
        <div>
          <h2 class="text-2xl font-extrabold text-primary font-heading leading-tight">Best Value</h2>
          <p class="text-sm text-muted mt-0.5">Highest quality-per-dollar across the entire catalog</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        {bestValue.map((product: Product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
