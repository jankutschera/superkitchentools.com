    },
    {
      question: `When should I replace my ${slug.replace(/-/g, " ")}?`,
      answer: "Replace when performance noticeably degrades, surfaces are worn or compromised, or safety is a concern. Quality kitchen tools should last 5-15 years with proper care.",
    },
  ];
}

// Task 5: Related categories mapping
function getRelatedCategories(slug: string): { slug: string; displayName: string }[] {
  const relatedMap: Record<string, string[]> = {
    "chefs-knives": ["cutting-boards", "cast-iron-cookware"],
    "cutting-boards": ["chefs-knives", "food-processors"],
    "cast-iron-cookware": ["chefs-knives", "baking-tools"],
    "air-fryers": ["pressure-cookers", "blenders"],
    "stand-mixers": ["food-processors", "baking-tools"],
    "coffee-makers": ["blenders"],
    "blenders": ["food-processors", "coffee-makers"],
    "food-processors": ["blenders", "stand-mixers"],
    "pressure-cookers": ["air-fryers", "cast-iron-cookware"],
    "baking-tools": ["stand-mixers", "kitchen-scales"],
    "kitchen-storage": ["spice-racks", "kitchen-gadgets"],
    "spice-racks": ["kitchen-storage", "kitchen-gadgets"],
    "kitchen-scales": ["baking-tools", "thermometers"],
    "thermometers": ["kitchen-scales", "cast-iron-cookware"],
    "kitchen-gadgets": ["kitchen-storage", "chefs-knives"],
  };
  const displayNames: Record<string, string> = {
    "chefs-knives": "Chef's Knives",
    "cutting-boards": "Cutting Boards",
    "cast-iron-cookware": "Cast Iron Cookware",
    "air-fryers": "Air Fryers",
    "stand-mixers": "Stand Mixers",
    "coffee-makers": "Coffee Makers",
    "blenders": "Blenders",
    "food-processors": "Food Processors",
    "pressure-cookers": "Pressure Cookers",
    "baking-tools": "Baking Tools",
    "kitchen-storage": "Kitchen Storage & Organization",
    "spice-racks": "Spice Racks & Containers",
    "kitchen-scales": "Kitchen Scales",
    "thermometers": "Kitchen Thermometers",
    "kitchen-gadgets": "Kitchen Gadgets & Utensils",
  };
  const related = relatedMap[slug] ?? [];
  return related.map((s) => ({ slug: s, displayName: displayNames[s] ?? s.replace(/-/g, " ") }));
}

const displayedProducts = products.slice(0, 10);
const top3Products = displayedProducts.slice(0, 3);
const faqs = getCategoryFAQs(category.slug);
const sisterSites = getSisterSitesForCategory(category.slug);
const firstSisterSite = sisterSites[0];
const relatedCategories = getRelatedCategories(category.slug);
const categoryIntro = getCategoryIntro(category.slug);
const trustContent = getTrustContent(category.slug);

const heroImageSrc = `/images/categories/${category.slug}.jpg`;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Best Picks", href: "/best/" },
  { label: `Best ${category.displayName}`, href: `/best/${category.slug}/` },
];

const schemas = [
  generateItemListSchema(displayedProducts, `Best ${category.displayName} 2026`),
  ...displayedProducts.map((p: Product) => generateProductSchema(p)),
  generateFAQSchema(faqs),
  generateBreadcrumbSchema([
    { name: "Home", url: "https://superkitchentools.com/" },
    { name: "Best Picks", url: "https://superkitchentools.com/best/" },
    { name: `Best ${category.displayName}`, url: `https://superkitchentools.com/best/${category.slug}/` },
  ]),
];
