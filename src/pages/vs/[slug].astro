---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import ProsConsList from "../../components/ProsConsList.astro";
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import SisterSiteLink from "../../components/SisterSiteLink.astro";
import RatingStars from "../../components/RatingStars.astro";
import DealBadge from "../../components/DealBadge.astro";
import { getProductByAsin } from "../../lib/products.ts";
import { getCategory } from "../../lib/categories.ts";
import { affiliateUrl } from "../../lib/affiliateUrl.ts";
import {
  generateProductSchema,
  generateFAQSchema,
  generateBreadcrumbSchema,
} from "../../lib/seo.ts";
import { getSisterSitesForCategory } from "../../lib/sisterSites.ts";
import comparisonsData from "../../../data/comparisons.json";

export function getStaticPaths() {
  return comparisonsData.map((comp) => ({
    params: { slug: comp.slug },
    props: {
      comparison: comp,
      productA: getProductByAsin(comp.productA),
      productB: getProductByAsin(comp.productB),
    },
  }));
}

const { comparison, productA, productB } = Astro.props;

if (!productA || !productB) {
  return Astro.redirect("/404");
}

const category = getCategory(comparison.categorySlug);
const categoryDisplayName = category?.displayName ?? comparison.categorySlug;

const winnerProduct =
  comparison.winner === productA.asin
    ? productA
    : comparison.winner === productB.asin
      ? productB
      : null;

const loserProduct =
  winnerProduct?.asin === productA.asin ? productB : productA;

const faqs = [
  {
    question: `${productA.name} vs ${productB.name}: which is better overall?`,
    answer: winnerProduct
      ? `Based on our analysis, the ${winnerProduct.name} wins overall. ${comparison.verdict}`
      : `It depends on your priorities. ${comparison.verdict}`,
  },
  {
    question: `Is the ${productA.name} or ${productB.name} better value for money?`,
    answer: `Check current prices on Amazon for the latest deals on both products. Value depends on your specific needs — consider which features matter most to you and whether the trade-offs in our comparison above are worth it for your cooking style.`,
  },
  {
    question: `Which should I choose: ${productA.name} or ${productB.name}?`,
    answer: `Choose the ${productA.name} if you prioritize ${(productA.pros[0] ?? "its strengths").toLowerCase()}. Choose the ${productB.name} if you prioritize ${(productB.pros[0] ?? "its strengths").toLowerCase()}. Our full comparison table above breaks down the differences point by point.`,
  },
];

const sisterSites = getSisterSitesForCategory(comparison.categorySlug);
const firstSisterSite = sisterSites[0];

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: `Best ${categoryDisplayName}`, href: `/best/${comparison.categorySlug}/` },
  { label: `${productA.name} vs ${productB.name}`, href: `/vs/${comparison.slug}/` },
];

const schemas = [
  generateProductSchema(productA),
  generateProductSchema(productB),
  generateFAQSchema(faqs),
  generateBreadcrumbSchema([
    { name: "Home", url: "https://superkitchentools.com/" },
    {
      name: `Best ${categoryDisplayName}`,
      url: `https://superkitchentools.com/best/${comparison.categorySlug}/`,
    },
    {
      name: `${productA.name} vs ${productB.name}`,
      url: `https://superkitchentools.com/vs/${comparison.slug}/`,
    },
  ]),
];
---

<BaseLayout
  title={`${productA.name} vs ${productB.name}: Which Is Better in 2026?`}
  description={`${productA.name} vs ${productB.name} — detailed head-to-head comparison. See which wins on ${comparison.comparisonPoints.slice(0, 3).map((p) => p.label.toLowerCase()).join(", ")}, and more.`}
  breadcrumbs={breadcrumbs}
  schemas={schemas}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Disclosure -->
    <AffiliateDisclosure variant="inline" />

    <!-- H1 -->
    <div class="w-28 h-1 bg-accent mt-8 mb-4"></div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-primary font-heading mb-2 leading-tight">
      {productA.name} vs {productB.name}
    </h1>
    <p class="text-muted text-sm mb-8">Which is better in 2026? We compared them head-to-head so you don't have to.</p>

    <!-- Winner Verdict Box -->
    {winnerProduct && (
      <div class="mb-10 rounded-xl border-2 border-accent/25 bg-amber-50/50 overflow-hidden shadow-sm">
        <div class="bg-amber-50 border-b border-accent/20 px-5 py-3">
          <p class="text-xs font-bold uppercase tracking-[0.1em] text-accent">Our Verdict</p>
        </div>
        <div class="p-5">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-4">
            <!-- Winner image -->
            <div class="w-16 h-16 rounded-xl bg-white border border-gray-200 overflow-hidden flex items-center justify-center p-1.5 shrink-0">
              <img
                src={winnerProduct.imageUrl}
                alt={winnerProduct.name}
                width="60"
                height="60"
                loading="eager"
                class="w-full h-full object-contain"
                onerror="this.style.display='none'"
              />
            </div>
            <div class="flex-1">
              <p class="text-xs font-semibold uppercase tracking-[0.1em] text-accent mb-1">Winner</p>
              <p class="text-lg font-bold text-primary font-heading leading-snug">{winnerProduct.name}</p>
              <div class="mt-1">
                <RatingStars rating={winnerProduct.rating} reviewCount={winnerProduct.reviewCount} />
              </div>
            </div>
            <a
              href={affiliateUrl(winnerProduct.asin)}
              rel="nofollow sponsored"
              target="_blank"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 transition-colors whitespace-nowrap shrink-0"
            >
              View on Amazon
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
          <p class="text-muted leading-relaxed text-sm">{comparison.verdict}</p>
        </div>
      </div>
    )}

    {!winnerProduct && (
      <div class="mb-10 rounded-xl border border-gray-200 bg-gray-50 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-muted mb-2">Our Verdict</p>
        <p class="text-muted leading-relaxed text-sm">{comparison.verdict}</p>
      </div>
    )}

    <!-- Full Comparison Table -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-primary font-heading mb-5">Full Comparison</h2>
      <ComparisonTable
        productA={productA}
        productB={productB}
        points={comparison.comparisonPoints}
      />
    </section>

    <!-- Individual Product Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

      <!-- Product A -->
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-5 py-4 flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-white border border-gray-100 overflow-hidden flex items-center justify-center p-1 shrink-0">
            <img
              src={productA.imageUrl}
              alt={productA.name}
              width="36"
              height="36"
              loading="lazy"
              class="w-full h-full object-contain"
              onerror="this.style.display='none'"
            />
          </div>
          <div class="min-w-0">
            <p class="text-xs text-muted font-medium">{productA.brand}</p>
            <h3 class="font-bold text-primary text-sm leading-snug font-heading line-clamp-2">
              <a href={`/reviews/${productA.slug}/`} class="hover:text-accent transition-colors">
                {productA.name}
              </a>
            </h3>
          </div>
          {winnerProduct?.asin === productA.asin && (
            <span class="ml-auto shrink-0">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-accent/10 text-accent text-xs font-bold border border-accent/20">
                Winner
              </span>
            </span>
          )}
        </div>
        <div class="p-5 flex flex-col gap-4">
          <RatingStars rating={productA.rating} reviewCount={productA.reviewCount} />
          <ProsConsList pros={productA.pros} cons={productA.cons} />
          <div class="pt-2 flex flex-col gap-2">
            <a
              href={affiliateUrl(productA.asin)}
              rel="nofollow sponsored"
              target="_blank"
              class="flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 transition-colors"
            >
              View on Amazon
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a
              href={`/reviews/${productA.slug}/`}
              class="flex items-center justify-center w-full py-2.5 px-4 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:bg-gray-50 transition-colors"
            >
              Full Review
            </a>
          </div>
        </div>
      </section>

      <!-- Product B -->
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-5 py-4 flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-white border border-gray-100 overflow-hidden flex items-center justify-center p-1 shrink-0">
            <img
              src={productB.imageUrl}
              alt={productB.name}
              width="36"
              height="36"
              loading="lazy"
              class="w-full h-full object-contain"
              onerror="this.style.display='none'"
            />
          </div>
          <div class="min-w-0">
            <p class="text-xs text-muted font-medium">{productB.brand}</p>
            <h3 class="font-bold text-primary text-sm leading-snug font-heading line-clamp-2">
              <a href={`/reviews/${productB.slug}/`} class="hover:text-accent transition-colors">
                {productB.name}
              </a>
            </h3>
          </div>
          {winnerProduct?.asin === productB.asin && (
            <span class="ml-auto shrink-0">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-accent/10 text-accent text-xs font-bold border border-accent/20">
                Winner
              </span>
            </span>
          )}
        </div>
        <div class="p-5 flex flex-col gap-4">
          <RatingStars rating={productB.rating} reviewCount={productB.reviewCount} />
          <ProsConsList pros={productB.pros} cons={productB.cons} />
          <div class="pt-2 flex flex-col gap-2">
            <a
              href={affiliateUrl(productB.asin)}
              rel="nofollow sponsored"
              target="_blank"
              class="flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 transition-colors"
            >
              View on Amazon
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a
              href={`/reviews/${productB.slug}/`}
              class="flex items-center justify-center w-full py-2.5 px-4 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:bg-gray-50 transition-colors"
            >
              Full Review
            </a>
          </div>
        </div>
      </section>
    </div>

    <!-- Our Pick + CTA -->
    {winnerProduct && loserProduct && (
      <section class="mb-12 bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-xl font-bold text-primary font-heading mb-3">Bottom Line: Our Pick</h2>
        <p class="text-muted leading-relaxed text-sm mb-5">{comparison.verdict}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href={affiliateUrl(winnerProduct.asin)}
            rel="nofollow sponsored"
            target="_blank"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 transition-colors"
          >
            Buy the {winnerProduct.name} on Amazon
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a
            href={`/reviews/${winnerProduct.slug}/`}
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:bg-gray-50 transition-colors"
          >
            Read Full Review
          </a>
          <a
            href={`/best/${comparison.categorySlug}/`}
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-primary text-sm font-semibold rounded-lg hover:bg-gray-50 transition-colors"
          >
            See All Best {categoryDisplayName}
          </a>
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section class="mb-12" aria-labelledby="faq-heading">
      <div class="mb-6">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-2">Common Questions</p>
        <h2 id="faq-heading" class="text-2xl font-bold text-primary font-heading">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="flex flex-col gap-3">
        {faqs.map((faq) => (
          <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none hover:bg-gray-50/70 transition-colors">
              <span class="font-semibold text-primary text-sm leading-snug">{faq.question}</span>
              <svg class="w-4 h-4 text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-2 text-muted text-sm leading-relaxed border-t border-gray-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Sister Site -->
    {firstSisterSite && (
      <div class="mt-8 pt-8 border-t border-gray-100">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-muted mb-3">From Our Network</p>
        <SisterSiteLink site={firstSisterSite} variant="card" />
      </div>
    )}

  </div>
</BaseLayout>
