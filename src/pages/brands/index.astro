---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllProducts, toBrandSlug } from "../../lib/products.ts";
import { generateBreadcrumbSchema } from "../../lib/seo.ts";
import type { Product } from "../../lib/products.ts";

const products = getAllProducts();

// Build brand map: brand -> { slug, count }
const brandMap = new Map<string, { slug: string; count: number }>();
for (const product of products) {
  const existing = brandMap.get(product.brand);
  if (existing) {
    existing.count += 1;
  } else {
    brandMap.set(product.brand, {
      slug: toBrandSlug(product.brand),
      count: 1,
    });
  }
}

// Sort alphabetically
const brands = [...brandMap.entries()]
  .map(([name, { slug, count }]) => ({ name, slug, count }))
  .sort((a, b) => a.name.localeCompare(b.name));

// Group by first letter
const grouped = brands.reduce<Record<string, typeof brands>>((acc, brand) => {
  const letter = brand.name[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(brand);
  return acc;
}, {});

const letters = Object.keys(grouped).sort();

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Brands", href: "/brands/" },
];

const schemas = [
  generateBreadcrumbSchema([
    { name: "Home", url: "https://superkitchentools.com/" },
    { name: "Brands", url: "https://superkitchentools.com/brands/" },
  ]),
];
---

<BaseLayout
  title="Kitchen Brands We Review — SuperKitchenTools 2026"
  description={`We review products from ${brands.length}+ kitchen equipment brands. Browse by brand to find expert-tested picks from KitchenAid, Lodge, Vitamix, Wüsthof, and more.`}
  breadcrumbs={breadcrumbs}
  schemas={schemas}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Hero -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary font-heading mb-4">
        Kitchen Brands We Review
      </h1>
      <p class="text-lg text-muted leading-relaxed max-w-3xl">
        We review products from {brands.length}+ kitchen equipment brands. Click any brand to
        see all of its reviewed products, ratings, and recommendations.
      </p>
    </div>

    <!-- Alpha jump links -->
    <nav class="mb-10 flex flex-wrap gap-1.5" aria-label="Jump to letter">
      {letters.map((letter) => (
        <a
          href={`#letter-${letter}`}
          class="inline-flex items-center justify-center w-9 h-9 text-sm font-bold text-muted border border-gray-200 rounded hover:border-accent/40 hover:text-accent hover:bg-gray-50 transition-colors"
        >
          {letter}
        </a>
      ))}
    </nav>

    <!-- Brand list grouped by letter -->
    <div class="space-y-10">
      {letters.map((letter) => (
        <section id={`letter-${letter}`}>
          <h2 class="text-xs font-bold uppercase tracking-widest text-muted mb-4 border-b border-gray-200 pb-2">
            {letter}
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {grouped[letter].map((brand) => (
              <li>
                <a
                  href={`/brands/${brand.slug}/`}
                  class="group flex items-center justify-between px-4 py-3 bg-white border border-gray-200 rounded-lg hover:border-accent/30 hover:shadow-sm transition-all duration-150"
                >
                  <span class="font-semibold text-primary group-hover:text-accent transition-colors">
                    {brand.name}
                  </span>
                  <span class="text-xs text-muted bg-gray-100 px-2 py-0.5 rounded-full">
                    {brand.count} {brand.count === 1 ? "product" : "products"}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

  </div>
</BaseLayout>
