---
import type { Product } from "../lib/products.ts";
import { affiliateUrl } from "../lib/affiliateUrl.ts";
import RatingStars from "./RatingStars.astro";
import DealBadge from "./DealBadge.astro";
import ProductImage from "./ProductImage.astro";

interface Props {
  product: Product;
  category?: string;
}

const { product, category = "" } = Astro.props;
const amazonUrl = affiliateUrl(product.asin);
const formatted = product.price.toLocaleString("en-US", {
  style: "currency",
  currency: "USD",
});
---

<aside
  class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
  style="position: sticky; top: 88px;"
>
  <!-- Header bar -->
  <div class="bg-gray-50 border-b border-gray-200 px-5 py-3 flex items-center justify-between">
    <p class="text-xs font-semibold uppercase tracking-[0.1em] text-muted">Our Top Pick</p>
    {product.isBestSeller && <DealBadge type="best-seller" />}
    {!product.isBestSeller && product.isAmazonChoice && <DealBadge type="amazon-choice" />}
  </div>

  <div class="p-5 flex flex-col gap-4">
    <!-- Product image -->
    <a href={amazonUrl} rel="nofollow sponsored" target="_blank" class="block group">
      <ProductImage
        src={product.imageUrl}
        alt={product.name}
        category={category || product.category}
        class="w-full max-w-[160px] mx-auto rounded-lg overflow-hidden"
        width={160}
        height={160}
      />
    </a>

    <!-- Product name -->
    <h3 class="font-bold text-sm text-primary leading-snug font-heading">{product.name}</h3>

    <!-- Rating -->
    <RatingStars rating={product.rating} reviewCount={product.reviewCount} />

    <!-- Price -->
    <div>
      <span class="text-2xl font-extrabold text-primary">{formatted}</span>
      <p class="text-xs text-muted mt-0.5">Price at time of writing</p>
    </div>

    <!-- CTA Button — primary -->
    <a
      href={amazonUrl}
      rel="nofollow sponsored"
      target="_blank"
      class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-accent text-white text-sm font-bold rounded-lg hover:bg-amber-600 active:scale-[0.98] transition-all"
    >
      View on Amazon
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>

    <!-- Key pros — compact -->
    {product.pros.length > 0 && (
      <ul class="flex flex-col gap-1.5 pt-1 border-t border-gray-100">
        {product.pros.slice(0, 3).map((pro) => (
          <li class="flex items-start gap-2 text-xs text-muted">
            <svg class="w-3.5 h-3.5 mt-0.5 text-success shrink-0 fill-current" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="line-clamp-2 leading-snug">{pro}</span>
          </li>
        ))}
      </ul>
    )}

    <!-- Affiliate disclaimer -->
    <p class="text-xs text-muted text-center border-t border-gray-100 pt-3 leading-snug">
      As an Amazon Associate, we earn from qualifying purchases.
    </p>
  </div>
</aside>
