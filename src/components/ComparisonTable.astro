---
import type { Product, ComparisonPoint } from "../lib/products.ts";
import { affiliateUrl } from "../lib/affiliateUrl.ts";

interface Props {
  productA: Product;
  productB: Product;
  points: ComparisonPoint[];
}

const { productA, productB, points } = Astro.props;
---

<div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
  <table class="w-full min-w-[560px] text-sm">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="w-1/3 px-5 py-4 text-left text-xs font-semibold uppercase tracking-[0.08em] text-muted">Feature</th>
        <th class="w-1/3 px-5 py-4 text-center">
          <a href={`/reviews/${productA.slug}/`} class="group flex flex-col items-center gap-1.5 hover:text-accent transition-colors">
            <!-- Image with fallback -->
            <div class="w-12 h-12 rounded-lg bg-white border border-gray-200 overflow-hidden flex items-center justify-center p-1">
              <img
                src={productA.imageUrl}
                alt={productA.name}
                width="44"
                height="44"
                loading="lazy"
                class="w-full h-full object-contain"
                onerror="this.style.display='none'"
              />
            </div>
            <span class="text-xs font-semibold text-primary group-hover:text-accent transition-colors leading-tight block line-clamp-2">
              {productA.name}
            </span>
          </a>
        </th>
        <th class="w-1/3 px-5 py-4 text-center">
          <a href={`/reviews/${productB.slug}/`} class="group flex flex-col items-center gap-1.5 hover:text-accent transition-colors">
            <div class="w-12 h-12 rounded-lg bg-white border border-gray-200 overflow-hidden flex items-center justify-center p-1">
              <img
                src={productB.imageUrl}
                alt={productB.name}
                width="44"
                height="44"
                loading="lazy"
                class="w-full h-full object-contain"
                onerror="this.style.display='none'"
              />
            </div>
            <span class="text-xs font-semibold text-primary group-hover:text-accent transition-colors leading-tight block line-clamp-2">
              {productB.name}
            </span>
          </a>
        </th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {points.map((point) => (
        <tr class="hover:bg-gray-50/70 transition-colors">
          <td class="px-5 py-3.5 font-medium text-primary">{point.label}</td>
          <td class={`px-5 py-3.5 text-center ${point.winner === "a" ? "bg-success/5 font-semibold text-success" : "text-muted"}`}>
            {point.winner === "a" && (
              <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-success text-white mr-1.5 shrink-0 align-middle">
                <svg class="w-2.5 h-2.5 fill-current" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
            )}
            {point.a}
          </td>
          <td class={`px-5 py-3.5 text-center ${point.winner === "b" ? "bg-success/5 font-semibold text-success" : "text-muted"}`}>
            {point.winner === "b" && (
              <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-success text-white mr-1.5 shrink-0 align-middle">
                <svg class="w-2.5 h-2.5 fill-current" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
            )}
            {point.b}
          </td>
        </tr>
      ))}
    </tbody>
    <tfoot>
      <tr class="bg-gray-50 border-t border-gray-200">
        <td class="px-5 py-4 font-semibold text-primary text-sm">Buy Now</td>
        <td class="px-5 py-4 text-center">
          <a
            href={affiliateUrl(productA.asin)}
            rel="nofollow sponsored"
            target="_blank"
            class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-accent text-white text-xs font-semibold rounded-lg hover:bg-amber-600 transition-colors"
          >
            View on Amazon
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </td>
        <td class="px-5 py-4 text-center">
          <a
            href={affiliateUrl(productB.asin)}
            rel="nofollow sponsored"
            target="_blank"
            class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-accent text-white text-xs font-semibold rounded-lg hover:bg-amber-600 transition-colors"
          >
            View on Amazon
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
