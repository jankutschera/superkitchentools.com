---
import type { Product, ComparisonPoint } from "../lib/products.ts";
import { affiliateUrl } from "../lib/affiliateUrl.ts";

interface Props {
  productA: Product;
  productB: Product;
  points: ComparisonPoint[];
}

const { productA, productB, points } = Astro.props;
---

<div class="overflow-x-auto rounded-xl border border-gray-200">
  <table class="w-full min-w-[560px] text-sm">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-200">
        <th class="w-1/3 px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Feature</th>
        <th class="w-1/3 px-4 py-3 text-center">
          <a href={`/reviews/${productA.slug}/`} class="block hover:text-accent transition-colors">
            <img
              src={productA.imageUrl}
              alt={productA.name}
              width="60"
              height="60"
              loading="lazy"
              class="w-12 h-12 object-contain mx-auto mb-1.5"
              onerror="this.src='/images/placeholder-product.svg'"
            />
            <span class="text-xs font-semibold text-primary leading-tight block line-clamp-2">
              {productA.name}
            </span>
          </a>
        </th>
        <th class="w-1/3 px-4 py-3 text-center">
          <a href={`/reviews/${productB.slug}/`} class="block hover:text-accent transition-colors">
            <img
              src={productB.imageUrl}
              alt={productB.name}
              width="60"
              height="60"
              loading="lazy"
              class="w-12 h-12 object-contain mx-auto mb-1.5"
              onerror="this.src='/images/placeholder-product.svg'"
            />
            <span class="text-xs font-semibold text-primary leading-tight block line-clamp-2">
              {productB.name}
            </span>
          </a>
        </th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {points.map((point) => (
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 font-medium text-primary">{point.label}</td>
          <td class={`px-4 py-3 text-center ${point.winner === "a" ? "bg-success/5 font-medium text-success" : "text-muted"}`}>
            {point.winner === "a" && (
              <span class="inline-block w-2 h-2 rounded-full bg-success mr-1.5 align-middle" aria-label="Winner" />
            )}
            {point.a}
          </td>
          <td class={`px-4 py-3 text-center ${point.winner === "b" ? "bg-success/5 font-medium text-success" : "text-muted"}`}>
            {point.winner === "b" && (
              <span class="inline-block w-2 h-2 rounded-full bg-success mr-1.5 align-middle" aria-label="Winner" />
            )}
            {point.b}
          </td>
        </tr>
      ))}
    </tbody>
    <tfoot>
      <tr class="bg-gray-50 border-t border-gray-200">
        <td class="px-4 py-3 font-semibold text-primary">Buy Now</td>
        <td class="px-4 py-3 text-center">
          <a
            href={affiliateUrl(productA.asin)}
            rel="nofollow sponsored"
            target="_blank"
            class="inline-flex items-center gap-1 px-3 py-1.5 bg-accent text-white text-xs font-semibold rounded-md hover:bg-accent/90 transition-colors"
          >
            View on Amazon
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </td>
        <td class="px-4 py-3 text-center">
          <a
            href={affiliateUrl(productB.asin)}
            rel="nofollow sponsored"
            target="_blank"
            class="inline-flex items-center gap-1 px-3 py-1.5 bg-accent text-white text-xs font-semibold rounded-md hover:bg-accent/90 transition-colors"
          >
            View on Amazon
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
