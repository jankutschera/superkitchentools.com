---
import type { SisterSite } from "../lib/sisterSites.ts";

interface Props {
  site: SisterSite;
  variant: "card" | "inline";
}

const { site, variant } = Astro.props;
---

{variant === "card" ? (
  <a
    href={site.url}
    target="_blank"
    rel="noopener"
    class="group flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-100 hover:border-accent/30 hover:shadow-sm transition-all"
  >
    <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center shrink-0 group-hover:bg-accent/20 transition-colors">
      <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-semibold text-primary group-hover:text-accent transition-colors">{site.name}</p>
      <p class="text-xs text-muted mt-0.5">{site.tagline}</p>
    </div>
    <svg class="w-4 h-4 text-muted group-hover:text-accent ml-auto shrink-0 mt-0.5 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
) : (
  <span class="text-sm text-muted">
    Looking for recipes? Visit{" "}
    <a
      href={site.url}
      target="_blank"
      rel="noopener"
      class="text-accent hover:underline font-medium"
    >
      {site.name}
    </a>
    {" "}— {site.tagline}.
  </span>
)}
