---
interface Props {
  type: "best-seller" | "amazon-choice" | "deal";
  text?: string;
}

const { type, text } = Astro.props;

const badgeConfig = {
  "best-seller": {
    label: text ?? "Best Seller",
    classes: "bg-amber-100 text-amber-800 border border-amber-200",
  },
  "amazon-choice": {
    label: text ?? "Amazon's Choice",
    classes: "bg-gray-900 text-white",
  },
  deal: {
    label: text ?? "Deal",
    classes: "bg-success/10 text-success border border-success/20",
  },
};

const config = badgeConfig[type];
---

<span
  class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-semibold leading-none ${config.classes}`}
>
  {type === "best-seller" && (
    <!-- Trophy icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="11"
      height="11"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
      <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
      <path d="M4 22h16" />
      <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
      <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
      <path d="M18 2H6v7a6 6 0 0 0 12 0V2z" />
    </svg>
  )}
  {type === "amazon-choice" && (
    <!-- Checkmark icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="11"
      height="11"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="20 6 9 17 4 12" />
    </svg>
  )}
  {type === "deal" && (
    <!-- Tag / deal icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="11"
      height="11"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
      <line x1="7" y1="7" x2="7.01" y2="7" />
    </svg>
  )}
  {config.label}
</span>
