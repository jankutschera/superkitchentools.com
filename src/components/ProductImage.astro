---
interface Props {
  src: string;
  alt: string;
  category?: string;
  class?: string;
  width?: number;
  height?: number;
}

const { src, alt, category = "", class: className = "", width = 400, height = 400 } = Astro.props;

// Unique ID to target this specific image's fallback
const id = `img-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={`product-image-wrap relative overflow-hidden bg-gray-50 ${className}`} id={id}>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    width={width}
    height={height}
    class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
    onerror={`
      var el = document.getElementById('${id}');
      if(el){
        var img = el.querySelector('img');
        var fallback = el.querySelector('.pf');
        if(img) img.style.display='none';
        if(fallback) fallback.style.display='flex';
      }
    `}
  />

  <!-- Fallback shown when image errors — styled gradient with icon + name -->
  <div
    class="pf absolute inset-0 flex-col items-center justify-center gap-3 bg-gradient-to-br from-gray-100 to-gray-200 p-4"
    style="display:none;"
    aria-hidden="true"
  >
    <!-- Generic kitchen utensil icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="40"
      height="40"
      viewBox="0 0 24 24"
      fill="none"
      stroke="#9CA3AF"
      stroke-width="1.25"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M3 21l12-12" />
      <path d="M6.5 17.5L18 3c1 0 3 1 3 3L7.5 17.5" />
      <path d="M3 21c0 0 2.5-.5 4-2" />
    </svg>
    <span class="text-xs text-gray-400 font-medium text-center leading-snug line-clamp-2 max-w-[120px]">{alt}</span>
  </div>
</div>
