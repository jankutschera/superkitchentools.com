---
import CategoryIcon from "./icons/CategoryIcon.astro";

interface Props {
  src: string;
  alt: string;
  category?: string;
  class?: string;
  width?: number;
  height?: number;
}

const { src, alt, category = "", class: className = "", width = 400, height = 400 } = Astro.props;

// Unique ID so the JS can target specific image's fallback
const id = `img-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={`product-image-wrap relative bg-gray-50 overflow-hidden ${className}`} id={id}>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    width={width}
    height={height}
    class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
    data-fallback="true"
    onerror={`document.getElementById('${id}').classList.add('img-broken')`}
  />
  <!-- Fallback overlay shown when image is broken via .img-broken class -->
  <div class="product-image-fallback absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-gray-100 to-gray-200 opacity-0 pointer-events-none" aria-hidden="true">
    <span class="text-gray-400">
      {category ? (
        <CategoryIcon slug={category} size={40} />
      ) : (
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
      )}
    </span>
    <span class="text-xs text-gray-400 font-medium px-4 text-center leading-snug line-clamp-2">{alt}</span>
  </div>
</div>

<style>
  .img-broken img {
    opacity: 0;
  }
  .img-broken .product-image-fallback {
    opacity: 1;
    pointer-events: auto;
  }
</style>
