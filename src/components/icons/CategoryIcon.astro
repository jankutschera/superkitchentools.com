---
interface Props {
  slug: string;
  class?: string;
  size?: number;
}

const { slug, class: className = "", size = 32 } = Astro.props;
---

{slug === "chefs-knives" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Chef's knife blade and handle -->
    <path d="M3 21l12-12" />
    <path d="M6.5 17.5L18 3c1 0 3 1 3 3L7.5 17.5" />
    <path d="M3 21c0 0 2.5-.5 4-2" />
  </svg>
)}

{slug === "cutting-boards" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Cutting board rectangle with handle -->
    <rect x="2" y="5" width="16" height="14" rx="1.5" />
    <path d="M18 10h3a1 1 0 0 1 0 4h-3" />
    <line x1="6" y1="9" x2="6" y2="15" />
    <line x1="10" y1="9" x2="10" y2="15" />
    <line x1="14" y1="9" x2="14" y2="15" />
  </svg>
)}

{slug === "cast-iron-cookware" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Skillet / frying pan -->
    <path d="M6 12a6 6 0 1 0 12 0 6 6 0 0 0-12 0z" />
    <path d="M6 12H2" />
    <path d="M2 10v4" />
  </svg>
)}

{slug === "air-fryers" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Air fryer — rounded body with fan/wind lines -->
    <rect x="4" y="6" width="16" height="14" rx="3" />
    <circle cx="12" cy="13" r="3" />
    <path d="M12 10V8" />
    <path d="M12 18v-2" />
    <path d="M9 13H7" />
    <path d="M17 13h-2" />
    <path d="M9.8 10.8L8.4 9.4" />
    <path d="M15.6 16.6l-1.4-1.4" />
    <path d="M9.8 15.2l-1.4 1.4" />
    <path d="M15.6 9.4l-1.4 1.4" />
    <rect x="8" y="3" width="8" height="3" rx="1" />
  </svg>
)}

{slug === "stand-mixers" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Stand mixer silhouette -->
    <path d="M8 20h8" />
    <path d="M12 20v-3" />
    <path d="M5 17h14a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1z" />
    <path d="M7 13V8a5 5 0 0 1 10 0" />
    <circle cx="17" cy="8" r="2" />
    <path d="M15 8l-3 5" />
  </svg>
)}

{slug === "coffee-makers" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Coffee cup with steam -->
    <path d="M17 8h1a4 4 0 0 1 0 8h-1" />
    <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z" />
    <line x1="6" y1="2" x2="6" y2="4" />
    <line x1="10" y1="2" x2="10" y2="4" />
    <line x1="14" y1="2" x2="14" y2="4" />
  </svg>
)}

{slug === "blenders" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Blender jar -->
    <path d="M8 3h8l1 7H7L8 3z" />
    <path d="M7 10l-2 9h14l-2-9" />
    <path d="M10 6h4" />
    <path d="M9 14c0 0 1-2 3-2s3 2 3 2" />
    <path d="M8 21h8" />
  </svg>
)}

{slug === "food-processors" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Food processor — bowl with blade/gear -->
    <rect x="4" y="10" width="16" height="10" rx="2" />
    <path d="M8 10V7a4 4 0 0 1 8 0v3" />
    <circle cx="12" cy="15" r="2" />
    <path d="M12 13v-1" />
    <path d="M12 18v-1" />
    <path d="M10.3 13.7l-.7-.7" />
    <path d="M14.4 17.7l-.7-.7" />
    <path d="M10.3 16.3l-.7.7" />
    <path d="M14.4 12.3l-.7.7" />
    <path d="M9 15h-1" />
    <path d="M16 15h-1" />
  </svg>
)}

{slug === "pressure-cookers" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Instant pot / pressure cooker -->
    <path d="M7 8h10a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2z" />
    <path d="M9 8V6a3 3 0 0 1 6 0v2" />
    <path d="M12 3v1" />
    <path d="M5 11H3" />
    <path d="M21 11h-2" />
    <path d="M8 19v2" />
    <path d="M16 19v2" />
    <!-- Steam valve -->
    <circle cx="12" cy="6" r="1" />
  </svg>
)}

{slug === "baking-tools" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    <!-- Rolling pin over flat surface -->
    <rect x="2" y="17" width="20" height="2" rx="1" />
    <rect x="6" y="9" width="12" height="6" rx="3" />
    <path d="M3 12H6" />
    <path d="M18 12h3" />
  </svg>
)}
