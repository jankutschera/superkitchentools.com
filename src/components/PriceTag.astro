---
interface Props {
  price: number;
  amazonUrl: string;
}

const { price, amazonUrl } = Astro.props;

const formatted = price.toLocaleString("en-US", {
  style: "currency",
  currency: "USD",
});
---

<div class="flex items-center gap-4">
  <div>
    <span class="text-2xl font-extrabold text-primary">{formatted}</span>
    <p class="text-xs text-muted mt-0.5">Price at time of writing</p>
  </div>
  <a
    href={amazonUrl}
    rel="nofollow sponsored"
    target="_blank"
    class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-accent text-white text-sm font-semibold rounded-lg hover:bg-amber-600 transition-colors whitespace-nowrap"
  >
    Check on Amazon
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>
