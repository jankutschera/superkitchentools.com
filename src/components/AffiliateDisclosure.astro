---
interface Props {
  variant: "inline" | "footer";
}

const { variant } = Astro.props;
---

{variant === "inline" ? (
  <p class="text-sm text-muted">
    We independently review everything we recommend. When you buy through our links, we may earn a commission.{" "}
    <a href="/disclosure/" class="text-accent hover:underline" aria-label="Learn more about our affiliate disclosure">Learn more</a>
  </p>
) : (
  <p class="text-xs text-gray-500 leading-relaxed">
    SuperKitchenTools is a participant in the Amazon Services LLC Associates Program.{" "}
    <a href="/disclosure/" class="hover:text-gray-300 transition-colors underline underline-offset-2">Affiliate Disclosure</a>
  </p>
)}
