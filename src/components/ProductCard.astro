---
import type { Product } from "../lib/products.ts";
import { affiliateUrl } from "../lib/affiliateUrl.ts";
import RatingStars from "./RatingStars.astro";
import DealBadge from "./DealBadge.astro";
import ProductImage from "./ProductImage.astro";

interface Props {
  product: Product;
  category?: string;
}

const { product, category = "" } = Astro.props;
const amazonUrl = affiliateUrl(product.asin);
const topPro = product.pros[0] ?? product.features[0] ?? "";
const formattedPrice = product.price.toLocaleString("en-US", {
  style: "currency",
  currency: "USD",
});
---

<article class="group bg-white rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col">

  <!-- Image area -->
  <a href={`/reviews/${product.slug}/`} class="block relative bg-gray-50 overflow-hidden" style="aspect-ratio: 4/3;">
    <ProductImage
      src={product.imageUrl}
      alt={product.name}
      category={category || product.category}
      class="absolute inset-0 w-full h-full"
    />
    <!-- Badges -->
    {(product.isBestSeller || product.isAmazonChoice) && (
      <div class="absolute top-3 left-3">
        {product.isBestSeller
          ? <DealBadge type="best-seller" />
          : <DealBadge type="amazon-choice" />
        }
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">

    <!-- Brand + Name -->
    <div class="mb-3">
      <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-muted mb-1">{product.brand}</p>
      <h3 class="font-bold text-primary leading-snug text-base line-clamp-2 font-heading">
        <a href={`/reviews/${product.slug}/`} class="hover:text-accent transition-colors">
          {product.name}
        </a>
      </h3>
    </div>

    <!-- Rating -->
    <div class="mb-3">
      <RatingStars rating={product.rating} reviewCount={product.reviewCount} />
    </div>

    <!-- Top pro — single most important feature -->
    {topPro && (
      <p class="text-sm text-muted leading-relaxed mb-4 flex-1 line-clamp-2">
        <svg class="inline-block w-3.5 h-3.5 mr-1 mb-0.5 text-success shrink-0 fill-current" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        {topPro}
      </p>
    )}

    <!-- Price + CTA — pinned to bottom -->
    <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between gap-3">
      <span class="text-xl font-extrabold text-primary">{formattedPrice}</span>
      <a
        href={amazonUrl}
        rel="nofollow sponsored"
        target="_blank"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-accent text-white text-xs font-semibold rounded-lg hover:bg-amber-600 transition-colors whitespace-nowrap"
      >
        Check Price
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</article>
