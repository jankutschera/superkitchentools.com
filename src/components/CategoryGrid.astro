---
import type { Category } from "../lib/products.ts";

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;

// Map category slugs to available hero images
const categoryImages: Record<string, string> = {
  "chefs-knives": "/images/categories/chefs-knives.jpg",
  "cutting-boards": "/images/categories/cutting-boards.jpg",
  "cast-iron-cookware": "/images/categories/cast-iron-cookware.jpg",
  "air-fryers": "/images/categories/air-fryers.jpg",
  "stand-mixers": "/images/categories/stand-mixers.jpg",
  "coffee-makers": "/images/categories/coffee-makers.jpg",
  "blenders": "/images/categories/blenders.jpg",
  "food-processors": "/images/categories/food-processors.jpg",
  "pressure-cookers": "/images/categories/pressure-cookers.jpg",
  "baking-tools": "/images/categories/baking-tools.jpg",
};
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
  {categories.map((category) => {
    const imgSrc = categoryImages[category.slug] ?? null;
    return (
      <a
        href={`/best/${category.slug}/`}
        class="group relative rounded-xl overflow-hidden aspect-[4/3] block"
        aria-label={`Best ${category.displayName}`}
      >
        {/* Photo background */}
        {imgSrc ? (
          <div
            class="absolute inset-0 category-hero-bg transition-transform duration-500 group-hover:scale-105"
            style={`background-image: url('${imgSrc}');`}
            aria-hidden="true"
          ></div>
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-gray-700 to-gray-900" aria-hidden="true"></div>
        )}

        {/* Dark gradient overlay — stronger at bottom */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/70 transition-all duration-300" aria-hidden="true"></div>

        {/* Text content at bottom */}
        <div class="absolute inset-x-0 bottom-0 p-3.5">
          <h3 class="text-white font-bold text-sm leading-tight font-heading drop-shadow-sm">
            {category.displayName}
          </h3>
          <p class="text-white/75 text-xs mt-0.5 font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200">
            See best picks &rarr;
          </p>
        </div>
      </a>
    );
  })}
</div>
