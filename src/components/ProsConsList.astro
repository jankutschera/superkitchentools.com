---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

  <!-- Pros -->
  <div class="rounded-xl border border-emerald-200 bg-emerald-50/50 overflow-hidden">
    <div class="px-4 py-2.5 border-b border-emerald-200 bg-emerald-50">
      <h4 class="text-xs font-bold text-success uppercase tracking-[0.1em] flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        What We Like
      </h4>
    </div>
    <ul class="p-4 flex flex-col gap-2.5">
      {pros.map((pro) => (
        <li class="flex items-start gap-2.5 text-sm text-primary">
          <svg class="w-3.5 h-3.5 mt-0.5 text-success shrink-0 fill-current" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="leading-snug">{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Cons -->
  <div class="rounded-xl border border-red-200 bg-red-50/40 overflow-hidden">
    <div class="px-4 py-2.5 border-b border-red-200 bg-red-50/70">
      <h4 class="text-xs font-bold text-red-600 uppercase tracking-[0.1em] flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Trade-offs
      </h4>
    </div>
    <ul class="p-4 flex flex-col gap-2.5">
      {cons.map((con) => (
        <li class="flex items-start gap-2.5 text-sm text-primary">
          <svg class="w-3.5 h-3.5 mt-0.5 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
          </svg>
          <span class="leading-snug">{con}</span>
        </li>
      ))}
    </ul>
  </div>

</div>
